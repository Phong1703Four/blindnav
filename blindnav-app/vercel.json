{
  "rewrites": [
    { "source": "/family", "destination": "/index.html" },
    { "source": "/user", "destination": "/user.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(*), microphone=(*), geolocation=(*)" }
      ]
    }
  ]
}
